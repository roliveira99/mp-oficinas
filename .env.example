# --- Opção 1: PostgreSQL local (Docker) ---
# Rode: npm run db:docker
DATABASE_URL="postgresql://mpoficinas:mpoficinas@localhost:5432/mpoficinas?schema=public"

# --- Opção 2: Neon (nuvem) — use a URL POOLED no Render/Vercel ---
# Neon → Dashboard → Connection details → "Pooled connection"
# Exemplo:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Render: Environment → DATABASE_URL = mesma string do Neon (atualize após trocar senha no Neon)

AUTH_SECRET="troque-por-um-segredo-longo-aleatorio"
